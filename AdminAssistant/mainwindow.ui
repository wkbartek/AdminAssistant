   <string notr="true">/* Tło całej aplikacji */
QMainWindow {
    background-color: #2b2b2b;
}

/* Etykiety tekstowe (Labels) */
QLabel {
    color: #ffffff;
    font-size: 14px;
    font-weight: bold;
}

/* Pola do wpisywania (Line Edit i Text Edit) */
QLineEdit, QTextEdit {
    background-color: #3c3f41;
    color: #ffffff;
    border: 1px solid #555555;
    border-radius: 5px;
    padding: 5px;
    font-size: 13px;
}

/* Przycisk wywołujący akcję */
QPushButton {
    background-color: #0078d7; /* Nowoczesny niebieski */
    color: white;
    border-radius: 5px;
    padding: 10px;
    font-size: 14px;
    font-weight: bold;
}

/* Efekt najechania myszką na przycisk */
QPushButton:hover {
    background-color: #005a9e; /* Nieco ciemniejszy niebieski */
}</string>
